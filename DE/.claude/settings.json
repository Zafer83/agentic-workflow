{
  "cli": {
    "auto_execute_commands": false,
    "file_ignore_patterns": [
      "**/node_modules/**",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/dist/**",
      "**/alembic/versions/**"
    ]
  },
  "project_context": {
